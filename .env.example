# Salin jadi .env untuk tes di laptop. JANGAN upload .env asli.

# Bot Telegram (boleh sama dengan tools lain). Tujuan laporan harian:
TELEGRAM_TOKEN=123456789:AAExample...
TELEGRAM_CHAT_IDS=12345678

# AI untuk merangkum (pakai kunci Gemini yang sudah Anda punya).
# Kosongkan untuk mode ringkas tanpa AI.
GEMINI_API_KEY=
AI_MODEL=gemini-2.5-flash-lite

# Isi "1" untuk mengisi contoh data saat uji pertama (tanpa agent). Production: "0".
SEED_DEMO=0
